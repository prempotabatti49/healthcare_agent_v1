{
  "expo": {
    "name": "Sunflower Health",
    "slug": "sunflower-health",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFDF0"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sunflowerhealth.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFDF0"
      },
      "package": "com.sunflowerhealth.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-document-picker",
      [
        "expo-image-picker",
        { "photosPermission": "Allow Sunflower to access your photos to upload health documents." }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:8000"
    }
  }
}
